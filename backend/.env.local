# =====================================================================
# MonkeyCode 本地局域网部署 - 环境变量
# ---------------------------------------------------------------------
# 使用方式：
#   docker compose -f docker-compose.local.yml --env-file .env.local up -d
# =====================================================================

# ---- 安装目录（volumes 的根，默认相对路径 ./data）----
INSTALL_DIR=.

# ---- PostgreSQL 配置 ----
POSTGRES_DB=monkeycode
POSTGRES_USER=monkeycode
POSTGRES_PASSWORD=mcai_local_dev_2026

# ---- Redis 配置 ----
REDIS_PASSWORD=mcai_local_redis

# ---- 本地主机 IP（前端 base_url / 回调地址会用到）----
# 请修改为运行 docker-compose 宿主机的局域网 IP，例如 192.168.1.100
LOCAL_IP=127.0.0.1

# ---- 镜像（如使用私有仓库可覆盖）----
BACKEND_IMAGE=ghcr.io/ghshhf/monkeycode/backend:latest
FRONTEND_IMAGE=ghcr.io/ghshhf/monkeycode/frontend:latest

# ---- 初始团队账号（backend 首次启动时自动创建）----
MCAI_INIT_TEAM_EMAIL=admin@example.com
MCAI_INIT_TEAM_NAME=Local Team
MCAI_INIT_TEAM_PASSWORD=admin123

# ---- 可选 Ollama 本地推理默认模型（可到 UI 中再改）----
# 常用：qwen2.5:7b, llama3.1:8b, deepseek-coder-v2:16b
MCAI_LLM_MODEL=qwen2.5:7b
